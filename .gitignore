# Maven build output: compiled .class files and the packaged .jar.
# Regenerated by every build, so it never gets versioned.
target/

# macOS Finder metadata. Created automatically; never belongs in the repo.
.DS_Store

# macOS custom folder icon. The real filename is "Icon" + a trailing
# carriage return; git strips a trailing CR from patterns, so we match
# that last byte with "?".
Icon?
